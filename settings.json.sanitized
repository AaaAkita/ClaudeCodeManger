{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "YOUR_ENV_ANTHROPIC_AUTH_TOKEN_HERE（env.ANTHROPIC_AUTH_TOKEN，请替换为真实值）",
    "ANTHROPIC_BASE_URL": "https://api.kimi.com/coding/",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "kimi-k2",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "K2.6-code-preview",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "kimi-k2.5",
    "ANTHROPIC_MODEL": "K2.6-code-preview",
    "ANTHROPIC_REASONING_MODEL": "K2.6-code-preview",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "MAX_THINKING_TOKENS": "31999",
    "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_ENV_GITHUB_PERSONAL_ACCESS_TOKEN_HERE（env.GITHUB_PERSONAL_ACCESS_TOKEN，请替换为真实值）",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "0",
    "ECC_AUTO_LEARNING": "true",
    "ECC_DISABLED_HOOKS": "",
    "ECC_HOOK_PROFILE": "standard",
    "ECC_LANGUAGES": "golang,typescript,vue,python",
    "ECC_MEMORY_PERSISTENCE": "true",
    "ECC_SECURITY_SCAN": "true",
    "ECC_VERSION": "1.8.0"
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(*)",
      "Grep(*)",
      "Glob(*)",
      "Agent(*)",
      "TaskCreate(*)",
      "TaskUpdate(*)"
    ],
    "ask": [
      "Bash(*rm -rf*)",
      "Bash(*git push --force*)",
      "Bash(*git reset --hard*)",
      "Bash(*DROP TABLE*)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline-command.sh\"",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/everything-claude-code.git"
      }
    }
  },
  "effortLevel": "high",
  "autoCompactWindow": 200000
}
